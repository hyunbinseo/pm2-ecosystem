{
	"include": ["*", "src/**/*"],
	"compilerOptions": {
		"strict": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		// JavaScript
		"allowJs": true,
		"checkJs": true,
		"outDir": "dist",

		// TypeScript
		"noEmit": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
	},
}
